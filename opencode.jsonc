{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "zai-coding-plan": {
      "models": {
        "glm-4.7": {
          "options": {
            "thinking": { "type": "disabled" },
          },
          "variants": {
            "thinking": {
              "thinking": { "type": "enabled" },
            },
          },
        },
        "glm-5-turbo": {
          "options": {
            "thinking": { "type": "disabled" },
          },
          "variants": {
            "thinking": {
              "thinking": { "type": "enabled" },
            },
          },
        },
        "glm-5.1": {
          "options": {
            "thinking": { "type": "disabled" },
          },
          "variants": {
            "thinking": {
              "thinking": { "type": "enabled" },
            },
          },
        },
      },
    },
  },
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": ["context-mode"],
    },
    "codegraph": {
      "type": "local",
      "command": ["codegraph", "serve", "--mcp"],
      "enabled": true,
    },
  },
  "formatter": {
    "gofmt": {
      "disabled": true,
    },
    "golangci-lint": {
      "command": ["golangci-lint", "fmt"],
      "extensions": [".go"],
    },
  },
  "lsp": {
    // rust-analyzer comsumes a lot of memory, disable it to save resources
    // Instead, rely on simple `cargo check` for Rust code check, you need to write it in AGENTS.md
    "rust": {
      "disabled": true,
    },
    // use ruff, ty/pyrefly/pyright for Python LSP, choose by yourself.
    "ruff": {
      "command": ["ruff", "server"],
      "extensions": [".py"],
    },
    "ty": {
      "command": ["ty", "server"],
      "extensions": [".py"],
    },
    "pyrefly": {
      "command": ["pyrefly", "lsp"],
      "extensions": [".py"],
      "disabled": true,
    },
    "pyright": {
      "disabled": true,
    },
    "golangci-lint": {
      "command": ["golangci-lint-langserver"],
      "extensions": [".go"],
      "initialization": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path",
          "stdout",
          "--show-stats=false",
          "--issues-exit-code=1",
        ],
      },
    },
  },
  // additional Context Mode settings
  "plugin": ["context-mode"],
  "instructions": [
    "https://raw.githubusercontent.com/mksglu/context-mode/refs/heads/main/configs/opencode/AGENTS.md",
  ],
}
